{
  "version": 1,
  "hooks": {
    "sessionStart": [
      {
        "type": "command",
        "powershell": "& \"$HOME\\.copilot\\hooks\\scripts\\persomemory-session-start.ps1\"",
        "timeoutSec": 5,
        "env": {
          "PERSOMEMORY_VAULT_PATH": "<VAULT_PATH>"
        }
      }
    ],
    "agentStop": [
      {
        "type": "command",
        "powershell": "& \"$HOME\\.copilot\\hooks\\scripts\\persomemory-agent-stop.ps1\"",
        "timeoutSec": 5
      }
    ],
    "sessionEnd": [
      {
        "type": "command",
        "powershell": "& \"$HOME\\.copilot\\hooks\\scripts\\persomemory-session-end.ps1\"",
        "timeoutSec": 5
      }
    ]
  }
}
