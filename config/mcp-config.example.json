{
  "mcpServers": {
    "workiq": {
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/workiq@latest",
        "mcp"
      ]
    },
    "workiq-teams": {
      "type": "http",
      "url": "https://agent365.svc.cloud.microsoft/agents/tenants/72f988bf-86f1-41af-91ab-2d7cd011db47/servers/mcp_TeamsServer"
    },
    "mcpvault": {
      "command": "npx",
      "args": [
        "@bitbonsai/mcpvault@latest",
        "C:\\Users\\<USERNAME>\\Repos\\ObsidianVaultMemory"
      ]
    },
    "smart-connections": {
      "command": "node",
      "args": [
        "C:\\Users\\<USERNAME>\\smart-connections-mcp\\dist\\index.js"
      ],
      "env": {
        "SMART_VAULT_PATH": "C:\\Users\\<USERNAME>\\Repos\\ObsidianVaultMemory"
      }
    },
    "persomemory-lifecycle": {
      "command": "node",
      "args": [
        "C:\\Users\\<USERNAME>\\persomemory-lifecycle-mcp\\index.js"
      ],
      "env": {
        "VAULT_PATH": "C:\\Users\\<USERNAME>\\Repos\\ObsidianVaultMemory"
      }
    }
  }
}
