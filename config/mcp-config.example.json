{
  "mcpServers": {
    "workiq": {
      "command": "npx",
      "args": [
        "-y",
        "@microsoft/workiq",
        "mcp"
      ]
    },
    "mcpvault": {
      "command": "npx",
      "args": [
        "@bitbonsai/mcpvault@latest",
        "/mnt/c/Users/flpydde/OneDrive - Microsoft/ProjectArchive/ObsidianVaultPersoMemory"
      ]
    },
    "smart-connections": {
      "command": "node",
      "args": [
        "/home/flpydde/smart-connections-mcp/dist/index.js"
      ],
      "env": {
        "SMART_VAULT_PATH": "/mnt/c/Users/flpydde/OneDrive - Microsoft/ProjectArchive/ObsidianVaultPersoMemory"
      }
    },
    "persomemory-lifecycle": {
      "command": "node",
      "args": [
        "/home/flpydde/persomemory-lifecycle-mcp/index.js"
      ],
      "env": {
        "VAULT_PATH": "/mnt/c/Users/flpydde/OneDrive - Microsoft/ProjectArchive/ObsidianVaultPersoMemory"
      }
    }
  }
}